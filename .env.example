# ─────────────────────────────────────────────────────────────────────────────
#  Frontend environment variables (Vite reads these at build/dev time)
# ─────────────────────────────────────────────────────────────────────────────
# Vite loads files in this priority (later overrides earlier):
#   1. .env                  (committed default for all modes)
#   2. .env.development      (committed, used by `npm run dev`)
#   3. .env.production       (committed, used by `npm run build`)
#   4. .env.local            (gitignored — your personal local override)
#   5. .env.development.local / .env.production.local (gitignored)
#
# Only variables prefixed VITE_ are exposed to the React app.
# To use locally: copy this file to `.env.local` and fill in real values.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the Spring Boot API — no trailing slash.
#   Local dev (Vite proxy):   /api/v1
#   Deployed same-host:       http://your-host.example.com/api/v1
#   Deployed split-host:      https://api.example.com/api/v1
VITE_API_URL=/api/v1

# Optional — Google Maps key for the PlacesAutocomplete component.
# Get one at https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=
